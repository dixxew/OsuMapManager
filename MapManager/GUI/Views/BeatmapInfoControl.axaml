<UserControl
	x:Class="MapManager.GUI.Views.BeatmapInfoControl"
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:iconPacks="https://github.com/MahApps/IconPacks.Avalonia"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:sukiUi="clr-namespace:SukiUI.Controls;assembly=SukiUI"
	xmlns:view="using:MapManager.GUI.Views"
	xmlns:vm="using:MapManager.GUI.ViewModels"
	d:DesignHeight="450"
	d:DesignWidth="800"
	mc:Ignorable="d">
	<UserControl.DataContext>
		<Binding Path="BeatmapInfoViewModel" Source="{StaticResource Locator}" />
	</UserControl.DataContext>
	<Grid RowDefinitions="*,auto">

		<!--  Background image  -->
		<sukiUi:GlassCard Margin="4">
			<Border
				Margin="-20"
				ClipToBounds="True"
				CornerRadius="16">
				<Image Source="{Binding MapBackground}" Stretch="UniformToFill" />
			</Border>
		</sukiUi:GlassCard>

		<!--  Info card  -->
		<sukiUi:GlassCard Grid.Row="1" Margin="4">
			<Grid RowDefinitions="auto, auto, auto">

				<!--  Row 0 — Artist / Title / Difficulty picker  -->
				<Border
					Padding="0,0,0,6"
					BorderBrush="Gray"
					BorderThickness="0,0,0,1">
					<Grid ColumnDefinitions="*, auto">
						<StackPanel Margin="0,-6,0,0" Orientation="Vertical">
							<TextBlock Text="{Binding SelectedBeatmapSet.Artist}" />
							<TextBlock
								VerticalAlignment="Center"
								FontSize="26"
								FontWeight="600"
								Foreground="White"
								Text="{Binding SelectedBeatmapSet.Title}" />
						</StackPanel>
						<StackPanel
							Grid.Column="1"
							VerticalAlignment="Center"
							Orientation="Horizontal"
							Spacing="6">
							<TextBlock
								VerticalAlignment="Center"
								FontSize="16"
								FontWeight="600"
								Text="{Binding SelectedBeatmap.Creator}" />
							<ComboBox
								Margin="0,0,-4,0"
								ItemsSource="{Binding SelectedBeatmapSet.Beatmaps}"
								SelectedItem="{Binding SelectedBeatmap, Mode=TwoWay}">
								<ComboBox.Styles>
									<Style Selector="ScrollViewer">
										<Setter Property="VerticalAlignment" Value="Center" />
										<Setter Property="Margin" Value="10" />
									</Style>
								</ComboBox.Styles>
								<ComboBox.ItemTemplate>
									<DataTemplate>
										<StackPanel Orientation="Horizontal" Spacing="6">
											<Ellipse
												Width="8"
												Height="8"
												VerticalAlignment="Center"
												Fill="{Binding StandardStarRating, Converter={StaticResource StarRatingToBrushConverter}}" />
											<TextBlock Text="{Binding Difficulty}" />
										</StackPanel>
									</DataTemplate>
								</ComboBox.ItemTemplate>
							</ComboBox>
						</StackPanel>
					</Grid>
				</Border>

				<!--  Row 1 — Stats (left) + Buttons (right)  -->
				<Grid
					Grid.Row="1"
					Margin="0,8,0,0"
					ColumnDefinitions="*, auto">

					<!--  Left: star rating, duration, objects, stat bars  -->
					<StackPanel Orientation="Vertical" Spacing="4">
						<StackPanel Orientation="Horizontal" Spacing="12">
							<Border
								Padding="8,2"
								VerticalAlignment="Center"
								Background="{Binding SelectedBeatmap.StandardStarRating, Converter={StaticResource StarRatingToBrushConverter}}"
								CornerRadius="10"
								ToolTip.Tip="Star rating">
								<StackPanel Orientation="Horizontal" Spacing="4">
									<iconPacks:PackIconFontAwesome
										Height="11"
										VerticalAlignment="Center"
										Foreground="#1C1719"
										Kind="StarSolid" />
									<TextBlock
										FontSize="13"
										FontWeight="700"
										Foreground="#1C1719"
										Text="{Binding SelectedBeatmap.StandardStarRating, StringFormat={}{0:0.00}}" />
								</StackPanel>
							</Border>
							<StackPanel Orientation="Horizontal" Spacing="5" ToolTip.Tip="Duration">
								<iconPacks:PackIconFontAwesome
									Height="13"
									VerticalAlignment="Center"
									Foreground="White"
									Kind="ClockSolid" />
								<TextBlock FontSize="15" Foreground="White" Text="{Binding SelectedBeatmap.Duration}" />
							</StackPanel>
							<StackPanel Orientation="Horizontal" Spacing="5" ToolTip.Tip="Objects">
								<iconPacks:PackIconFontAwesome
									Height="13"
									VerticalAlignment="Center"
									Foreground="White"
									Kind="BullseyeSolid" />
								<TextBlock FontSize="15" Foreground="White" Text="{Binding SelectedBeatmap.ObjectsCount}" />
							</StackPanel>
						</StackPanel>

						<!--  Stat bars  -->
						<Grid
							Margin="0,4,0,0"
							ColumnDefinitions="auto, auto"
							RowDefinitions="auto, auto">
							<Grid.Styles>
								<Style Selector="TextBlock.statLabel">
									<Setter Property="FontSize" Value="11" />
									<Setter Property="Width" Value="22" />
									<Setter Property="Foreground" Value="LightGray" />
									<Setter Property="VerticalAlignment" Value="Center" />
								</Style>
								<Style Selector="TextBlock.statValue">
									<Setter Property="FontSize" Value="11" />
									<Setter Property="Width" Value="30" />
									<Setter Property="Foreground" Value="White" />
									<Setter Property="VerticalAlignment" Value="Center" />
									<Setter Property="Margin" Value="6,0,14,0" />
								</Style>
								<Style Selector="ProgressBar">
									<Setter Property="Width" Value="76" />
									<Setter Property="Height" Value="4" />
									<Setter Property="Minimum" Value="0" />
									<Setter Property="Maximum" Value="10" />
									<Setter Property="VerticalAlignment" Value="Center" />
								</Style>
								<Style Selector="StackPanel">
									<Setter Property="Margin" Value="0,2" />
								</Style>
							</Grid.Styles>
							<StackPanel Orientation="Horizontal">
								<TextBlock Classes="statLabel" Text="AR" />
								<ProgressBar Value="{Binding SelectedBeatmap.ApproachRate}" />
								<TextBlock Classes="statValue" Text="{Binding SelectedBeatmap.ApproachRate, StringFormat={}{0:0.#}}" />
							</StackPanel>
							<StackPanel Grid.Column="1" Orientation="Horizontal">
								<TextBlock Classes="statLabel" Text="CS" />
								<ProgressBar Value="{Binding SelectedBeatmap.CircleSize}" />
								<TextBlock Classes="statValue" Text="{Binding SelectedBeatmap.CircleSize, StringFormat={}{0:0.#}}" />
							</StackPanel>
							<StackPanel Grid.Row="1" Orientation="Horizontal">
								<TextBlock Classes="statLabel" Text="HP" />
								<ProgressBar Value="{Binding SelectedBeatmap.HPDrain}" />
								<TextBlock Classes="statValue" Text="{Binding SelectedBeatmap.HPDrain, StringFormat={}{0:0.#}}" />
							</StackPanel>
							<StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
								<TextBlock Classes="statLabel" Text="OD" />
								<ProgressBar Value="{Binding SelectedBeatmap.OverallDifficulty}" />
								<TextBlock Classes="statValue" Text="{Binding SelectedBeatmap.OverallDifficulty, StringFormat={}{0:0.#}}" />
							</StackPanel>
						</Grid>
					</StackPanel>

					<!--  Right: collections dropdown + action buttons  -->
					<StackPanel
						Grid.Column="1"
						Margin="8,0,0,0"
						Orientation="Vertical"
						Spacing="4">
						<DropDownButton>
							<StackPanel Orientation="Horizontal" Spacing="6">
								<iconPacks:PackIconFontAwesome
									Height="12"
									VerticalAlignment="Center"
									Kind="LayerGroupSolid" />
								<TextBlock VerticalAlignment="Center" Text="{Binding SelectedBeatmapCollectionsCount}" />
							</StackPanel>
							<DropDownButton.Flyout>
								<Flyout>
									<Panel>
										<Border
											Margin="20"
											BoxShadow="{DynamicResource SukiPopupShadow}"
											CornerRadius="20" />
										<Border
											MinWidth="350"
											Margin="20"
											Background="{DynamicResource SukiCardBackground}"
											BorderBrush="{DynamicResource SukiLightBorderBrush}"
											BorderThickness="1"
											ClipToBounds="True"
											CornerRadius="15">
											<Border Padding="15" Background="{DynamicResource PopupGradientBrush}">
												<view:BeatmapBlockCollectionsControl />
											</Border>
										</Border>
									</Panel>
								</Flyout>
							</DropDownButton.Flyout>
						</DropDownButton>
						<Button Classes="Basic" Command="{Binding OpenBeatmapInOsu}">
							<StackPanel Orientation="Horizontal" Spacing="6">
								<iconPacks:PackIconFontAwesome
									Height="12"
									VerticalAlignment="Center"
									Kind="UpRightFromSquareSolid" />
								<TextBlock VerticalAlignment="Center" Text="Open in osu!" />
							</StackPanel>
						</Button>
						<Button Classes="Basic" Command="{Binding LookSimilar}">
							<StackPanel Orientation="Horizontal" Spacing="6">
								<iconPacks:PackIconFontAwesome
									Height="12"
									VerticalAlignment="Center"
									Kind="MagnifyingGlassSolid" />
								<TextBlock VerticalAlignment="Center" Text="Look similar" />
							</StackPanel>
						</Button>
					</StackPanel>
				</Grid>

				<!--  Row 2 — Tags  -->
				<ScrollViewer
					Grid.Row="2"
					MaxHeight="60"
					Margin="0,6,0,0"
					HorizontalScrollBarVisibility="Disabled"
					VerticalScrollBarVisibility="Auto">
					<ItemsControl ItemsSource="{Binding Tags}">
						<ItemsControl.ItemsPanel>
							<ItemsPanelTemplate>
								<WrapPanel Orientation="Horizontal" />
							</ItemsPanelTemplate>
						</ItemsControl.ItemsPanel>
						<ItemsControl.ItemTemplate>
							<DataTemplate DataType="vm:BeatmapTagViewModel">
								<Button
									Margin="2,2"
									Padding="8,4"
									Classes.active="{Binding IsActive}"
									Command="{Binding ToggleCommand}"
									CornerRadius="8">
									<Button.Styles>
										<Style Selector="Button">
											<Setter Property="Background" Value="#191435" />
											<Setter Property="BorderThickness" Value="0" />
											<Setter Property="Foreground" Value="White" />
										</Style>
										<Style Selector="Button:pointerover /template/ ContentPresenter">
											<Setter Property="Background" Value="#251E4A" />
										</Style>
										<Style Selector="Button.active">
											<Setter Property="Background" Value="#3D2070" />
										</Style>
										<Style Selector="Button.active:pointerover /template/ ContentPresenter">
											<Setter Property="Background" Value="#4D2D8A" />
										</Style>
									</Button.Styles>
									<TextBlock FontSize="10" Foreground="White" Text="{Binding Tag}" />
								</Button>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>
				</ScrollViewer>

			</Grid>
		</sukiUi:GlassCard>
	</Grid>
</UserControl>
