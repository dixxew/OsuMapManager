<UserControl
	x:Class="MapManager.GUI.Views.BeatmapsSearchControl"
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:iconPacks="https://github.com/MahApps/IconPacks.Avalonia"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:sukiUi="clr-namespace:SukiUI.Controls;assembly=SukiUI"
	xmlns:view="using:MapManager.GUI.Views"
	d:DesignHeight="450"
	d:DesignWidth="800"
	mc:Ignorable="d">
	<UserControl.DataContext>
		<Binding Path="BeatmapsSearchViewModel" Source="{StaticResource Locator}" />
	</UserControl.DataContext>
	<sukiUi:GlassCard Padding="12,6" Classes="Primary">
		<StackPanel Orientation="Vertical">
			<DockPanel>
				<RadioButton Margin="0,0,-3,0" IsChecked="{Binding SearchMode, Converter={StaticResource BeatmapsSearchModeToBoolConverter}, ConverterParameter=QUERY}" />
				<TextBox
					FlowDirection="LeftToRight"
					Text="{Binding SearchBeatmapSetText}"
					Watermark="Search, ex: 'Sotarks We Are' or use Filters">
					<TextBox.InnerLeftContent>
						<iconPacks:PackIconFontAwesome
							Height="13"
							Margin="8,0,0,0"
							VerticalAlignment="Center"
							Foreground="Gray"
							Kind="MagnifyingGlassSolid" />
					</TextBox.InnerLeftContent>
				</TextBox>
			</DockPanel>
			<DockPanel Margin="0,0,6,0">
				<StackPanel Orientation="Horizontal" Spacing="8">
					<RadioButton Margin="0,0,-6,0" IsChecked="{Binding SearchMode, Converter={StaticResource BeatmapsSearchModeToBoolConverter}, ConverterParameter=FILTERS}" />
					<DropDownButton Padding="12,8" FontSize="12">
						<StackPanel Orientation="Horizontal" Spacing="6">
							<iconPacks:PackIconFontAwesome
								Height="11"
								VerticalAlignment="Center"
								Kind="FilterSolid" />
							<TextBlock VerticalAlignment="Center" Text="Filters" />
						</StackPanel>
						<DropDownButton.Flyout>
							<Flyout>
								<Panel>
									<Border
										Margin="20"
										BoxShadow="{DynamicResource SukiPopupShadow}"
										CornerRadius="20" />
									<Border
										MinWidth="350"
										Margin="20"
										Background="{DynamicResource SukiCardBackground}"
										BorderBrush="{DynamicResource SukiLightBorderBrush}"
										BorderThickness="1"
										ClipToBounds="True"
										CornerRadius="15">
										<Border Padding="15" Background="{DynamicResource PopupGradientBrush}">
											<view:SearchFiltersControl />
										</Border>
									</Border>
								</Panel>
							</Flyout>
						</DropDownButton.Flyout>
					</DropDownButton>
					<ToggleButton
						Padding="10,8"
						VerticalAlignment="Center"
						IsEnabled="{Binding IsAnyBeatmap}"
						IsChecked="{Binding IsShowOnlyFavorites}"
						ToolTip.Tip="Only favorites">
						<ToggleButton.Styles>
							<Style Selector="ToggleButton iconPacks|PackIconFontAwesome">
								<Setter Property="Foreground" Value="Gray" />
							</Style>
							<Style Selector="ToggleButton:checked iconPacks|PackIconFontAwesome">
								<Setter Property="Foreground" Value="#e0507a" />
							</Style>
							<Style Selector="ToggleButton">
								<Setter Property="Foreground" Value="White" />
								<Setter Property="Padding" Value="8 0" />
								<Setter Property="BorderBrush" Value="Transparent" />
							</Style>
							<Style Selector="ToggleButton:pointerover /template/ Border">
								<Setter Property="BorderBrush" Value="Transparent" />
							</Style>
							<Style Selector="ToggleButton:pointerover /template/ ContentPresenter">
								<Setter Property="BorderBrush" Value="Transparent" />
							</Style>
							<Style Selector="ToggleButton:pointerover /template/ Border">
								<Setter Property="BorderBrush" Value="Transparent" />
							</Style>
							<Style Selector="ToggleButton:pointerover /template/ ContentPresenter">
								<Setter Property="Foreground" Value="White" />
								<Setter Property="Background" Value="Transparent" />
							</Style>
							<Style Selector="ToggleButton:unchecked /template/ ContentPresenter">
								<Setter Property="BorderBrush" Value="Transparent" />
								<Setter Property="Background" Value="Transparent" />
							</Style>
							<Style Selector="ToggleButton:checked /template/ ContentPresenter">
								<Setter Property="Background" Value="Transparent" />
								<Setter Property="BorderBrush" Value="Transparent" />
							</Style>
						</ToggleButton.Styles>
						<StackPanel Orientation="Horizontal" Spacing="4">
							<TextBlock>My</TextBlock>
							<iconPacks:PackIconFontAwesome
								Height="13"
								VerticalAlignment="Center"
								Kind="HeartSolid" />
						</StackPanel>
					</ToggleButton>
				</StackPanel>
				<StackPanel
					HorizontalAlignment="Right"
					Orientation="Horizontal"
					Spacing="10">
					<TextBlock
						VerticalAlignment="Center"
						FontSize="12"
						Foreground="LightGray">
						<Run Text="{Binding BeatmapsCount}" />
						<Run Text="maps" />
					</TextBlock>
					<DropDownButton
						Padding="10,8"
						FontSize="12"
						ToolTip.Tip="Options">
						<iconPacks:PackIconFontAwesome
							Height="13"
							VerticalAlignment="Center"
							Kind="SlidersSolid" />
						<DropDownButton.Flyout>
						<Flyout>
							<Panel>
								<Border
									Margin="20"
									BoxShadow="{DynamicResource SukiPopupShadow}"
									CornerRadius="20" />
								<Border
									MinWidth="350"
									Margin="20"
									Background="{DynamicResource SukiCardBackground}"
									BorderBrush="{DynamicResource SukiLightBorderBrush}"
									BorderThickness="1"
									ClipToBounds="True"
									CornerRadius="15">
									<Border Padding="15" Background="{DynamicResource PopupGradientBrush}">
										<view:SearchOptionsControl />
									</Border>
								</Border>
							</Panel>
						</Flyout>
						</DropDownButton.Flyout>
					</DropDownButton>
				</StackPanel>
			</DockPanel>

			<Grid
				Width="{Binding $parent.Bounds.Width}"
				Margin="0,4"
				ColumnDefinitions="Auto,*"
				IsVisible="{Binding IsReferenceSearhcing}">
				<RadioButton Margin="0,0,6,0" IsChecked="{Binding SearchMode, Converter={StaticResource BeatmapsSearchModeToBoolConverter}, ConverterParameter=SAME}" />
				<Grid Grid.Column="1" ColumnDefinitions="auto, auto, *">
					<TextBlock
						Grid.Column="0"
						Margin="0,0,6,0"
						VerticalAlignment="Center"
						FontWeight="600"
						Text="Similar:" />
					<StackPanel
						Grid.Column="1"
						Margin="0,0,6,0"
						Orientation="Vertical">
						<TextBlock Text="{Binding ReferenceBeatmap.Title}" />
						<TextBlock FontSize="8" Text="{Binding ReferenceBeatmap.Artist}" />
					</StackPanel>
					<ScrollViewer
						x:Name="TagScrollViewer"
						Grid.Column="2"
						VerticalAlignment="Center"
						Background="Transparent"
						Focusable="True"
						HorizontalScrollBarVisibility="Hidden"
						VerticalScrollBarVisibility="Disabled">
						<ItemsControl ItemsSource="{Binding ReferenceBeatmap.TagsList}">
							<ItemsControl.ItemsPanel>
								<ItemsPanelTemplate>
									<WrapPanel Orientation="Horizontal" />
								</ItemsPanelTemplate>
							</ItemsControl.ItemsPanel>
							<ItemsControl.ItemTemplate>
								<DataTemplate>
									<Border
										Margin="2,1"
										Padding="6,2"
										Background="#191435"
										CornerRadius="8">
										<TextBlock
											FontSize="8"
											Foreground="White"
											Text="{Binding}" />
									</Border>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>
					</ScrollViewer>
				</Grid>
			</Grid>

		</StackPanel>
	</sukiUi:GlassCard>
</UserControl>
