<UserControl
	x:Class="MapManager.GUI.Views.CollectionsControl"
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:iconPacks="https://github.com/MahApps/IconPacks.Avalonia"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:model="using:MapManager.GUI.Models"
	xmlns:sukiUi="clr-namespace:SukiUI.Controls;assembly=SukiUI"
	d:DesignHeight="450"
	d:DesignWidth="800"
	mc:Ignorable="d">
	<UserControl.DataContext>
		<Binding Path="CollectionsViewModel" Source="{StaticResource Locator}" />
	</UserControl.DataContext>
	<UserControl.Styles>
		<Style Selector="TextBlock">
			<Setter Property="FontSize" Value="18" />
		</Style>
	</UserControl.Styles>
	<Grid>
		<TreeView
			Grid.Row="1"
			ItemsSource="{Binding Collections}"
			SelectedItem="{Binding SelectedTreeViewCollection}"
			SelectionMode="Single">
			<TreeView.Styles>
				<Style Selector="ScrollViewer">
					<Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
					<Setter Property="VerticalScrollBarVisibility" Value="Hidden" />
				</Style>
			</TreeView.Styles>
			<TreeView.DataTemplates>
				<!-- Collection node: uses AllItems so both Beatmap and MissingBeatmap appear as children -->
				<TreeDataTemplate DataType="model:Collection" ItemsSource="{Binding AllItems}">
					<Grid ColumnDefinitions="* auto" RowDefinitions="Auto 4 Auto">
						<StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
							<TextBlock
								VerticalAlignment="Center"
								FontSize="14"
								FontWeight="600"
								Text="{Binding Name}" />
							
						</StackPanel>
						<StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
							<Button
								Padding="6,2"
								VerticalAlignment="Center"
								Classes="Outlined Rounded"
								Click="ExportClick"
								FontSize="12">
								<StackPanel Orientation="Horizontal" Spacing="4">
									<iconPacks:PackIconFontAwesome
										Height="10"
										VerticalAlignment="Center"
										Kind="FileExportSolid" />
									<TextBlock FontSize="10" VerticalAlignment="Center" Text="Export" />
								</StackPanel>
							</Button>
							<Button
								Padding="6,2"
								VerticalAlignment="Center"
								Classes="Outlined Rounded"
								Command="{Binding $parent[UserControl].DataContext.RemoveCollection}"
								CommandParameter="{Binding}"
								FontSize="12">
								<iconPacks:PackIconFontAwesome
									Height="10"
									VerticalAlignment="Center"
									Kind="TrashSolid" />
							</Button>
						</StackPanel>
						<StackPanel Grid.Row="2" >
							<!-- Missing badge -->
							<Border
								Padding="5,1"
								VerticalAlignment="Center"
								Background="#55ff8800"
								CornerRadius="4"
								IsVisible="{Binding HasMissing}">
								<StackPanel Orientation="Horizontal" Spacing="4">
									<iconPacks:PackIconFontAwesome
										Height="9"
										VerticalAlignment="Center"
										Foreground="Orange"
										Kind="TriangleExclamationSolid" />
									<TextBlock
										VerticalAlignment="Center"
										FontSize="10"
										Foreground="Orange"
										Text="{Binding MissingCount, StringFormat='{}{0} нет на диске'}" />
								</StackPanel>
							</Border>
						</StackPanel>
						<StackPanel HorizontalAlignment="Right" Grid.Row="2" Grid.Column="1">
							
							<!-- Download all missing — visible only when there are missing maps -->
							<Button
								Padding="6,2"
								VerticalAlignment="Center"
								Classes="Outlined Rounded"
								Command="{Binding $parent[UserControl].DataContext.DownloadAllMissingCommand}"
								CommandParameter="{Binding}"
								IsVisible="{Binding HasMissing}"
								ToolTip.Tip="Скачать все отсутствующие карты"
								FontSize="12">
								<StackPanel Orientation="Horizontal" Spacing="4">
									<iconPacks:PackIconFontAwesome
										Height="10"
										VerticalAlignment="Center"
										Foreground="Orange"
										Kind="CloudArrowDownSolid" />
									<TextBlock FontSize="10" VerticalAlignment="Center" Foreground="Orange" Text="Скачать все" />
								</StackPanel>
							</Button>
						</StackPanel>
					</Grid>
				</TreeDataTemplate>

				<!-- Regular beatmap leaf -->
				<DataTemplate DataType="model:Beatmap">
					<Grid
						Width="{Binding $parent[UserControl].Bounds.Width, Converter={StaticResource TreeViewWidthByParentConveter}}"
						Margin="-28,0,0,0"
						ColumnDefinitions="* auto">
						<StackPanel Grid.Column="0" HorizontalAlignment="Left" Orientation="Vertical">
							<TextBlock FontSize="12" Foreground="LightGray" Text="{Binding Artist}" />
							<TextBlock FontSize="16" Text="{Binding Title}" />
						</StackPanel>
						<StackPanel
							Grid.Column="1"
							HorizontalAlignment="Right"
							Orientation="Horizontal"
							Spacing="4">
							<TextBlock VerticalAlignment="Center" FontSize="12" Text="{Binding Difficulty}" />
							<Button
								Margin="0"
								Padding="8,4"
								VerticalAlignment="Center"
								Classes="Outlined Rounded"
								Click="OnRemoveClick"
								ToolTip.Tip="Remove from collection">
								<iconPacks:PackIconFontAwesome Height="10" Kind="XmarkSolid" />
							</Button>
						</StackPanel>
					</Grid>
				</DataTemplate>

				<!-- Missing beatmap leaf -->
				<DataTemplate DataType="model:MissingBeatmap">
					<Grid
						Width="{Binding $parent[UserControl].Bounds.Width, Converter={StaticResource TreeViewWidthByParentConveter}}"
						Margin="-28,0,0,0"
						ColumnDefinitions="* auto"
						Opacity="0.6">
						<StackPanel Grid.Column="0" HorizontalAlignment="Left" Orientation="Vertical">
							<TextBlock
								FontSize="12"
								Foreground="Orange"
								Text="{Binding Artist}"
								IsVisible="{Binding IsResolved}" />
							<TextBlock
								FontSize="14"
								Foreground="LightGray"
								Text="{Binding DisplayName}"
								TextTrimming="CharacterEllipsis" />
						</StackPanel>
						<Button
							Grid.Column="1"
							Margin="0"
							Padding="8,4"
							VerticalAlignment="Center"
							Classes="Outlined Rounded"
							Command="{Binding $parent[UserControl].DataContext.DownloadMissingCommand}"
							CommandParameter="{Binding}"
							ToolTip.Tip="Скачать с зеркала">
							<StackPanel Orientation="Horizontal" Spacing="4">
								<iconPacks:PackIconFontAwesome
									Height="10"
									VerticalAlignment="Center"
									Kind="CloudArrowDownSolid" />
							</StackPanel>
						</Button>
					</Grid>
				</DataTemplate>
			</TreeView.DataTemplates>
		</TreeView>
		<sukiUi:Loading
			HorizontalAlignment="Center"
			VerticalAlignment="Center"
			IsVisible="{Binding IsLoading}" />
	</Grid>
</UserControl>
