<UserControl
	x:Class="MapManager.MainControl"
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:iconPacks="https://github.com/MahApps/IconPacks.Avalonia"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:model="using:MapManager.GUI.Models"
	xmlns:sukiUi="clr-namespace:SukiUI.Controls;assembly=SukiUI"
	xmlns:view="using:MapManager.GUI.Views"
	xmlns:vm="using:MapManager.GUI.ViewModels"
	d:DesignHeight="450"
	d:DesignWidth="800"
	mc:Ignorable="d">
	<Grid>
		<Grid ColumnDefinitions="2*, 8, 6*">
			<Grid.Styles>
				<Style Selector="Grid">
					<Setter Property="Background" Value="Transparent" />
				</Style>
			</Grid.Styles>
			<Image
				Grid.ColumnSpan="3"
				Opacity="0.27"
				Source="{Binding MapBackground}"
				Stretch="UniformToFill">
				<Image.DataContext>
					<Binding Path="BeatmapInfoViewModel" Source="{StaticResource Locator}" />
				</Image.DataContext>
				<Image.Effect>
					<BlurEffect Radius="35" />
				</Image.Effect>
			</Image>

			<Grid Background="#0fffffff">
				<TabControl SelectedIndex="{Binding SelectedMainTab}">
					<TabItem>
						<TabItem.Header>
							<StackPanel
								Margin="8,0"
								Orientation="Horizontal"
								Spacing="8">
								<iconPacks:PackIconFontAwesome
									Height="15"
									VerticalAlignment="Center"
									Kind="MapSolid" />
								<TextBlock
									FontSize="18"
									FontWeight="Bold"
									Text="Maps" />
							</StackPanel>
						</TabItem.Header>
						<Grid RowDefinitions="auto, *">
							<view:BeatmapsSearchControl />
							<Grid Grid.Row="1">
								<view:BeatmapsControl />
							</Grid>
						</Grid>
					</TabItem>
					<TabItem>
						<TabItem.Header>
							<StackPanel
								Margin="8,0"
								Orientation="Horizontal"
								Spacing="8">
								<iconPacks:PackIconFontAwesome
									Height="15"
									VerticalAlignment="Center"
									Kind="LayerGroupSolid" />
								<TextBlock
									FontSize="18"
									FontWeight="Bold"
									Text="Collections" />
							</StackPanel>
						</TabItem.Header>
						<Grid RowDefinitions="auto, *">
							<view:CollectionsSearchControl />
							<Grid Grid.Row="1">
								<view:CollectionsControl />
							</Grid>
						</Grid>
					</TabItem>
				</TabControl>
			</Grid>

			<Grid Grid.Column="2">
				<Grid
					Grid.Row="1"
					Margin="4"
					RowDefinitions="*, auto">
					<UserControl Content="{Binding MainBlockContent}" />
					<view:AudioPlayerControl
						Grid.Row="1"
						Margin="4"
						VerticalAlignment="Bottom" />
				</Grid>
			</Grid>
		</Grid>
	</Grid>
</UserControl>
