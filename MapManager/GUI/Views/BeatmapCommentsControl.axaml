<UserControl
    x:Class="MapManager.GUI.Views.BeatmapCommentsControl"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:iconPacks="https://github.com/MahApps/IconPacks.Avalonia"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sukiUi="clr-namespace:SukiUI.Controls;assembly=SukiUI"
    d:DesignHeight="450"
    d:DesignWidth="300"
    mc:Ignorable="d">
    <UserControl.DataContext>
        <Binding Path="BeatmapCommentsViewModel" Source="{StaticResource Locator}" />
    </UserControl.DataContext>

    <Grid>
        <!--  Loading  -->
        <sukiUi:Loading
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            IsVisible="{Binding IsLoading}" />

        <!--  Empty state  -->
        <StackPanel
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            IsVisible="{Binding IsEmpty}"
            Spacing="8">
            <iconPacks:PackIconFontAwesome
                Width="36"
                Height="36"
                HorizontalAlignment="Center"
                Foreground="LightGray"
                Kind="CommentsRegular" />
            <TextBlock
                HorizontalAlignment="Center"
                FontSize="13"
                Foreground="LightGray"
                Text="No comments yet" />
        </StackPanel>

        <!--  Comment list  -->
        <ScrollViewer IsVisible="{Binding !IsLoading}">
            <ItemsControl ItemsSource="{Binding Comments}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,5">
                            <Grid ColumnDefinitions="42,*">

                                <!--  Avatar  -->
                                <Border
                                    Width="36"
                                    Height="36"
                                    VerticalAlignment="Top"
                                    ClipToBounds="True"
                                    CornerRadius="36">
                                    <Panel>
                                        <Rectangle Fill="#2a2a3a" />
                                        <Image Source="{Binding User.Avatar}" Stretch="UniformToFill" />
                                    </Panel>
                                </Border>

                                <!--  Content  -->
                                <StackPanel
                                    Grid.Column="1"
                                    Orientation="Vertical"
                                    Spacing="3">

                                    <!--  Header row  -->
                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                        <StackPanel
                                            Grid.Column="0"
                                            Orientation="Horizontal"
                                            Spacing="5">
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                FontSize="12"
                                                FontWeight="600"
                                                Foreground="White"
                                                Text="{Binding User.Username}" />
                                            <iconPacks:PackIconFontAwesome
                                                Height="9"
                                                VerticalAlignment="Center"
                                                Foreground="Gold"
                                                IsVisible="{Binding Pinned}"
                                                Kind="ThumbtackSolid"
                                                ToolTip.Tip="Pinned" />
                                        </StackPanel>

                                        <StackPanel
                                            Grid.Column="2"
                                            Orientation="Horizontal"
                                            Spacing="6">
                                            <StackPanel
                                                IsVisible="{Binding HasVotes}"
                                                Orientation="Horizontal"
                                                Spacing="3">
                                                <iconPacks:PackIconFontAwesome
                                                    Height="9"
                                                    VerticalAlignment="Center"
                                                    Foreground="#e0507a"
                                                    Kind="HeartSolid" />
                                                <TextBlock
                                                    VerticalAlignment="Center"
                                                    FontSize="11"
                                                    Foreground="#e0507a"
                                                    Text="{Binding VotesCount}" />
                                            </StackPanel>
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                FontSize="11"
                                                Foreground="Gray"
                                                Text="{Binding TimeAgo}" />
                                        </StackPanel>
                                    </Grid>

                                    <!--  Message  -->
                                    <TextBlock
                                        FontSize="12"
                                        Foreground="#d0d0d0"
                                        Text="{Binding Message}"
                                        TextWrapping="Wrap" />

                                    <!--  Replies hint  -->
                                    <StackPanel
                                        IsVisible="{Binding HasReplies}"
                                        Orientation="Horizontal"
                                        Spacing="4">
                                        <iconPacks:PackIconFontAwesome
                                            Height="8"
                                            VerticalAlignment="Center"
                                            Foreground="Gray"
                                            Kind="ReplyAllSolid" />
                                        <TextBlock FontSize="10" Foreground="Gray">
                                            <Run Text="{Binding RepliesCount}" />
                                            <Run Text=" replies" />
                                        </TextBlock>
                                    </StackPanel>

                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
