<UserControl
	x:Class="MapManager.GUI.Views.BeatmapsControl"
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:sukiUi="clr-namespace:SukiUI.Controls;assembly=SukiUI"
	mc:Ignorable="d">
	<UserControl.DataContext>
		<Binding Path="BeatmapsViewModel" Source="{StaticResource Locator}" />
	</UserControl.DataContext>
	<UserControl.Styles>
		<Style Selector="TextBlock">
			<Setter Property="FontSize" Value="18" />
		</Style>
	</UserControl.Styles>
	<Grid>
		<ListBox
			x:Name="BeatmapsListBox"
			FontWeight="550"
			Foreground="White"
			ItemsSource="{Binding FilteredBeatmapSets}"
			ScrollViewer.VerticalScrollBarVisibility="Hidden"
			
			SelectedItem="{Binding SelectedBeatmapSet}">
			<ListBox.Styles>
				<Style Selector="ListBoxItem">
					<Setter Property="Padding" Value="-2" />
				</Style>
				<Style Selector="ListBoxItem /template/ PathIcon#CheckSelected">
					<Setter Property="IsVisible" Value="False" />
				</Style>
			</ListBox.Styles>
			<ListBox.ItemTemplate>
				<DataTemplate>
					<Grid ColumnDefinitions="auto, *, auto" MaxWidth="{Binding $parent.Bounds.Width}">
						<!--
							Thumbnail: first child = behind content.
							ColumnSpan=3 → gets full item width.
							Inner 3*/2* columns → left 60% gets the image.
							Stretch=Fill → reports 0x0 during measure, so item height
							is determined by the text content below, not the image.
						-->
						<!--
							Canvas reports 0x0 desired size → item height = text content.
							After arrange, Bounds give real item size → Border fills exactly.
						-->
						<Canvas
							Grid.Column="0"
							Grid.ColumnSpan="3"
							HorizontalAlignment="Stretch"
							VerticalAlignment="Stretch"
							IsHitTestVisible="False">
							<Border
								Canvas.Left="-2"
								Canvas.Top="0"
								Width="{Binding $parent[Canvas].Bounds.Width}"
								Height="{Binding $parent[Canvas].Bounds.Height}"
								CornerRadius="6"
								Opacity="0.9"
								ClipToBounds="True">
								<Image Source="{Binding Thumbnail}" Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center" />
								<Border.OpacityMask>
									<LinearGradientBrush StartPoint="0%,100%" EndPoint="100%,100%">
										<GradientStop Color="Black" Offset="0" />
										<GradientStop Color="#aa000000" Offset="0.2" />
										<GradientStop Color="#88000000" Offset="0.4" />
										<GradientStop Color="Transparent" Offset="1" />
									</LinearGradientBrush>
								</Border.OpacityMask>
							</Border>
						</Canvas>
						<!-- Content -->
						<Ellipse
							Width="8"
							Height="8"
							Margin="4,0,8,0"
							VerticalAlignment="Center"
							Fill="{Binding Beatmaps[0].RankedStatus, Converter={StaticResource RankedStatusToBrushConverter}}"
							ToolTip.Tip="{Binding Beatmaps[0].RankedStatus}" />
						<TextBlock Grid.Column="1" FontSize="18" MaxWidth="{Binding $parent[ColumnDefinition].Bounds.Width}" Text="{Binding Title}" />
						<StackPanel Grid.Column="2" HorizontalAlignment="Right" Orientation="Vertical">
							<TextBlock
								MaxWidth="100"
								HorizontalAlignment="Right"
								FontSize="10"
								Foreground="LightGray"
								Text="{Binding Artist}"
								TextTrimming="CharacterEllipsis" />
							<TextBlock
								HorizontalAlignment="Right"
								FontSize="10"
								Foreground="Gray"
								Text="{Binding Beatmaps[0].Creator}" />
						</StackPanel>
					</Grid>
				</DataTemplate>
			</ListBox.ItemTemplate>
		</ListBox>
		<sukiUi:Loading
			HorizontalAlignment="Center"
			VerticalAlignment="Center"
			IsVisible="{Binding IsLoading}" />
	</Grid>
</UserControl>
