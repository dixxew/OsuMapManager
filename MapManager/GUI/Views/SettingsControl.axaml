<UserControl
	x:Class="MapManager.GUI.Views.SettingsControl"
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:iconPacks="https://github.com/MahApps/IconPacks.Avalonia"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:sukiUi="clr-namespace:SukiUI.Controls;assembly=SukiUI"
	d:DesignHeight="450"
	d:DesignWidth="800"
	mc:Ignorable="d">
	<UserControl.DataContext>
		<Binding Path="SettingsViewModel" Source="{StaticResource Locator}" />
	</UserControl.DataContext>
	<Grid>
		<ScrollViewer>
			<StackPanel Spacing="9">
				<StackPanel.Styles>
					<Style Selector="TextBlock">
						<Setter Property="FontSize" Value="18" />
						<Setter Property="VerticalAlignment" Value="Center" />
						<Setter Property="FontWeight" Value="550" />
					</Style>
				</StackPanel.Styles>
				<sukiUi:GlassCard>
					<StackPanel FlowDirection="LeftToRight" Orientation="Horizontal">
						<iconPacks:PackIconFontAwesome
							Height="14"
							Margin="0,0,8,0"
							VerticalAlignment="Center"
							Kind="FolderOpenSolid" />
						<TextBlock Text="Osu path:" />
						<TextBox
							Width="250"
							Text="{Binding OsuDirPath}"
							Watermark="D:\osu!" />
					</StackPanel>
				</sukiUi:GlassCard>
				<sukiUi:GlassCard>
					<DockPanel FlowDirection="LeftToRight">
						<StackPanel Orientation="Horizontal">
							<iconPacks:PackIconFontAwesome
								Height="14"
								Margin="0,0,8,0"
								VerticalAlignment="Center"
								Kind="KeySolid" />
							<TextBlock Text="Osu api key:" />
						</StackPanel>
						<StackPanel
							HorizontalAlignment="Right"
							Orientation="Horizontal"
							Spacing="4">
							<TextBox
								Width="250"
								Text="{Binding OsuClientSecret}"
								Watermark="App key" />
							<TextBox
								Width="100"
								Text="{Binding OsuClientId}"
								Watermark="App ID" />
							<Button
								Margin="8,5"
								HorizontalAlignment="Right"
								Classes="Standard Icon"
								Command="{Binding OpenWebPageOsuApiKey}">
								<StackPanel Orientation="Horizontal">
									<TextBlock Text="Get" />
									<iconPacks:PackIconForkAwesome
										Height="14"
										VerticalAlignment="Center"
										Kind="GlobeW" />
								</StackPanel>
							</Button>
						</StackPanel>
					</DockPanel>
				</sukiUi:GlassCard>
				<sukiUi:GlassCard>
					<DockPanel FlowDirection="LeftToRight">
						<StackPanel Orientation="Horizontal">
							<iconPacks:PackIconFontAwesome
								Height="14"
								Margin="0,0,8,0"
								VerticalAlignment="Center"
								Kind="CommentsSolid" />
							<TextBlock Text="IRC" />
						</StackPanel>
						<StackPanel
							HorizontalAlignment="Right"
							Orientation="Horizontal"
							Spacing="4">
							<TextBox
								Width="250"
								Text="{Binding IrcNickname}"
								Watermark="Nickname" />
							<TextBox
								Width="100"
								PasswordChar="*"
								Text="{Binding IrcPassword}"
								Watermark="Password" />
							<Button
								Margin="8,5"
								Classes="Standard Icon"
								Command="{Binding OpenWebPageOsuApiKey}">
								<StackPanel Orientation="Horizontal">
									<TextBlock Text="Get" />
									<iconPacks:PackIconForkAwesome
										Height="14"
										VerticalAlignment="Center"
										Kind="GlobeW" />
								</StackPanel>
							</Button>
						</StackPanel>
					</DockPanel>
				</sukiUi:GlassCard>
				<sukiUi:GlassCard>
					<StackPanel Orientation="Horizontal">
						<iconPacks:PackIconFontAwesome
							Height="14"
							Margin="0,0,8,0"
							VerticalAlignment="Center"
							Kind="PaletteSolid" />
						<TextBlock Text="Theme:" />
						<ItemsControl Margin="6,-6,-6,-6" VerticalAlignment="Center" ItemsSource="{Binding ThemeColors}">
						<ItemsControl.ItemsPanel>
							<ItemsPanelTemplate>
								<WrapPanel Orientation="Horizontal" />
							</ItemsPanelTemplate>
						</ItemsControl.ItemsPanel>
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Button
									Width="24"
									Height="24"
									Margin="2,0"
									Background="{Binding Converter={StaticResource ColorToBrushConverter}}"
									Command="{Binding $parent[UserControl].DataContext.SetThemeColor}"
									CommandParameter="{Binding}" />
							</DataTemplate>
						</ItemsControl.ItemTemplate>
						</ItemsControl>
					</StackPanel>
				</sukiUi:GlassCard>
				<sukiUi:GlassCard>
					<DockPanel FlowDirection="LeftToRight">
						<StackPanel Orientation="Horizontal">
							<iconPacks:PackIconFontAwesome
								Height="14"
								Margin="0,0,8,0"
								VerticalAlignment="Center"
								Kind="DatabaseSolid" />
							<TextBlock Text="Cache:" />
						</StackPanel>
						<StackPanel
							HorizontalAlignment="Right"
							Orientation="Horizontal"
							Spacing="8">
							<TextBlock
								VerticalAlignment="Center"
								FontSize="13"
								IsVisible="{Binding CacheInvalidated}"
								Opacity="0.7"
								Text="Данные обновятся при следующих запросах" />
							<Button
								Margin="0,5"
								Classes="Standard"
								Command="{Binding InvalidateCacheCommand}">
								<StackPanel Orientation="Horizontal" Spacing="6">
									<iconPacks:PackIconFontAwesome
										Height="13"
										VerticalAlignment="Center"
										Kind="ArrowRightArrowLeftSolid" />
									<TextBlock Text="Сбросить кеш" />
								</StackPanel>
							</Button>
						</StackPanel>
					</DockPanel>
				</sukiUi:GlassCard>
				<StackPanel HorizontalAlignment="Right" Orientation="Horizontal" Spacing="8">
					<TextBlock
						VerticalAlignment="Center"
						FontSize="10"
						Foreground="Gray"
						Text="{Binding AppVersion, StringFormat='v{0}'}" />
					<TextBlock
						VerticalAlignment="Center"
						FontSize="10"
						Foreground="Gray"
						IsVisible="{Binding IsCheckingUpdate}"
						Text="checking for updates…" />
					<TextBlock
						VerticalAlignment="Center"
						FontSize="10"
						Foreground="#4caf50"
						IsVisible="{Binding IsUpToDate}"
						Text="up to date" />
					<Button
						Classes="Basic"
						Command="{Binding OpenReleasePageCommand}"
						IsVisible="{Binding HasUpdate}"
						ToolTip.Tip="Open releases page">
						<StackPanel Orientation="Horizontal" Spacing="4">
							<iconPacks:PackIconFontAwesome
								Width="10"
								Height="10"
								VerticalAlignment="Center"
								Foreground="#ff9800"
								Kind="ArrowUpSolid" />
							<TextBlock
								VerticalAlignment="Center"
								FontSize="10"
								Foreground="#ff9800"
								Text="{Binding LatestVersion, StringFormat='v{0} available'}" />
						</StackPanel>
					</Button>
					<Button
						Classes="Basic"
						Command="{Binding CheckUpdateCommand}"
						IsVisible="{Binding !IsCheckingUpdate}"
						ToolTip.Tip="Check for updates">
						<iconPacks:PackIconFontAwesome
							Width="10"
							Height="10"
							Foreground="Gray"
							Kind="ArrowsRotateSolid" />
					</Button>
				</StackPanel>
			</StackPanel>
		</ScrollViewer>
	</Grid>
</UserControl>
