<UserControl
	x:Class="MapManager.GUI.Dialogs.ChannelPickerDialogView"
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:local="clr-namespace:MapManager.GUI.Dialogs"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	d:DesignHeight="450"
	d:DesignWidth="300"
	x:DataType="local:ChannelPickerDialogViewModel"
	mc:Ignorable="d">
	<StackPanel Orientation="Vertical" Spacing="12">
		<ScrollViewer MaxHeight="400" VerticalScrollBarVisibility="Auto">
			<ItemsControl ItemsSource="{Binding Channels}">
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<Button
							Margin="0,2"
							Padding="12,6"
							HorizontalAlignment="Stretch"
							HorizontalContentAlignment="Left"
							Command="{Binding $parent[UserControl].DataContext.Join}"
							CommandParameter="{Binding}"
							Content="{Binding}"
							FontSize="16" />
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>
		</ScrollViewer>
		<Button
			HorizontalAlignment="Right"
			Command="{Binding Dismiss}"
			Content="Cancel" />
	</StackPanel>
</UserControl>
